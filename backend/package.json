{
  "name": "retro-bot-backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma generate && tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "db:migrate": "npx prisma migrate dev",
    "db:deploy": "node --env-file=.env ./node_modules/prisma/build/index.js migrate deploy",
    "db:generate": "node --env-file=.env ./node_modules/prisma/build/index.js generate",
    "db:ensure-db": "node scripts/ensure-retrobot-db.cjs",
    "db:setup": "npm run db:ensure-db && npm run db:deploy && npm run db:generate && npm run db:seed",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:reset": "npx prisma migrate reset",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.1",
    "@prisma/client": "^6.19.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@emnapi/core": "^1.9.2",
    "@emnapi/runtime": "^1.9.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pino-http": "^5.8.4",
    "@types/swagger-ui-express": "^4.1.8",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.2",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
