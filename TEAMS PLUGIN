        <mxCell id="Oqm262Eo2yBclkro6cRZ-61" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="Пояснения по TEMPLATES:&lt;div&gt;У нас есть 3 шаблона:&amp;nbsp;&lt;/div&gt;&lt;div&gt;1. Start, Stop, Continue (Код: SSC)&lt;/div&gt;&lt;div&gt;2. Mad, Sad, Glad (Код: MSG)&lt;/div&gt;&lt;div&gt;3.&amp;nbsp;Liked, Learned, Lacked,&amp;nbsp; Longed for (Код: 4L)&lt;br&gt;&lt;br&gt;Для каждого типа соответствуют свои значения, которые создают код из аббревиатуры.&lt;/div&gt;&lt;div&gt;Значения типа хранятся в TEMPLATE_VALUES. И создается ограничение при создании таблицы, типа:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;INSERT INTO template_type_values (template_type_id, code)&lt;/div&gt;&lt;div&gt;SELECT id, &#39;START&#39; FROM template_types WHERE code = &#39;SSC&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;INSERT INTO template_type_values (template_type_id, code)&lt;/div&gt;&lt;div&gt;SELECT id, &#39;STOP&#39; FROM template_types WHERE code = &#39;SSC&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;INSERT INTO template_type_values (template_type_id, code)&lt;/div&gt;&lt;div&gt;SELECT id, &#39;CONTINUE&#39; FROM template_types WHERE code = &#39;SSC&#39;;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;INSERT INTO template_type_values (template_type_id, code)&lt;/div&gt;&lt;div&gt;SELECT id, &#39;MAD&#39; FROM template_types WHERE code = &#39;MSG&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;INSERT INTO template_type_values (template_type_id, code)&lt;/div&gt;&lt;div&gt;SELECT id, &#39;SAD&#39; FROM template_types WHERE code = &#39;MSG&#39;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;INSERT INTO template_type_values (template_type_id, code)&lt;/div&gt;&lt;div&gt;SELECT id, &#39;GLAD&#39; FROM template_types WHERE code = &#39;MSG&#39;;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&lt;/div&gt;&lt;div&gt;и т.д.&lt